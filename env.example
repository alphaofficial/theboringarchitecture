# Required in production. Generate with: openssl rand -hex 32
SESSION_SECRET=your_session_secret_here

# Required in production. Used for HMAC token signing. Generate with: openssl rand -hex 32
APP_KEY=your_app_key_here

# App
NODE_ENV=development
PORT=3000
APP_NAME=The Boring Architecture
APP_URL=http://localhost:3000

# Trust proxy: 'loopback', 'true', a number of hops, or an IP/CIDR list.
# Set to 'true' (or your LB CIDR) when running behind a reverse proxy.
TRUST_PROXY=loopback

# Session
SESSION_MAX_AGE=86400000

# Database
DB_PATH=theboringarchitecture.db

# Rate limiting (off by default)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_FEATURE_MAX=60
RATE_LIMIT_FEATURE_WINDOW_MS=60000

# Password reset expiry in minutes (default 60)
PASSWORD_RESET_EXPIRY=60

# Email verification expiry in minutes (default 60)
EMAIL_VERIFICATION_EXPIRY=60

# Mailer (log driver writes emails to the logger; use smtp for production)
MAIL_DRIVER=log
MAIL_FROM=noreply@example.com
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=smtp_user
# MAIL_PASS=smtp_password

# Cache (memory driver is default; swap in redis or another driver as needed)
CACHE_DRIVER=memory

# File Storage (local driver writes to STORAGE_PATH)
STORAGE_DRIVER=local
STORAGE_PATH=storage

# S3 Storage (only required when STORAGE_DRIVER=s3)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_ENDPOINT=https://s3.custom-endpoint.com

# Queue (Graphile Worker — requires PostgreSQL; omit to disable)
# DATABASE_URL=postgres://user:pass@localhost:5432/theboringarchitecture

# Scheduler (set to true to enable cron-based task scheduler)
SCHEDULER_ENABLED=false

# SSR (server-side rendering). On by default; set to false to ship a client-only shell.
SSR_ENABLED=true
