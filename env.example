# Required in production. Generate with: openssl rand -hex 32
SESSION_SECRET=your_session_secret_here

# Required in production. Used for HMAC token signing. Generate with: openssl rand -hex 32
APP_KEY=your_app_key_here

# App
NODE_ENV=development
PORT=3000
APP_NAME=Hatch JS
APP_URL=http://localhost:3000

# Trust proxy: 'loopback', 'true', a number of hops, or an IP/CIDR list.
# Set to 'true' (or your LB CIDR) when running behind a reverse proxy.
TRUST_PROXY=loopback

# Session
SESSION_MAX_AGE=86400000

# Database
DB_PATH=hatch.db

# Rate limiting (off by default)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=60000

# Password reset expiry in minutes (default 60)
PASSWORD_RESET_EXPIRY=60

# Mailer (log driver writes emails to the logger; use smtp for production)
MAIL_DRIVER=log
MAIL_FROM=noreply@example.com
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=smtp_user
# MAIL_PASS=smtp_password

# Cache (memory driver is default; swap in redis or another driver as needed)
CACHE_DRIVER=memory
