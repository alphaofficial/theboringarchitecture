{
  "name": "theboringarchitecture",
  "version": "0.1.0",
  "description": "The Boring Architecture — a fullstack starter for Express, Inertia, and React.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently --names \"pages,server,client,ssr\" --prefix-colors \"yellow,cyan,magenta,blue\" \"npm run pages:watch\" \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:ssr\"",
    "dev:server": "nodemon --exec tsx src/index.ts",
    "dev:client": "vite build --watch",
    "dev:ssr": "vite build --config vite.ssr.config.mjs --watch",
    "scaffold": "bash scripts/scaffold.sh",
    "pages:generate": "tsx scripts/generate-pages.ts",
    "pages:watch": "chokidar \"src/views/pages/**/*.tsx\" -c \"npm run pages:generate\" --initial",
    "predev": "npm run pages:generate && npm run build:ssr",
    "prebuild": "npm run pages:generate",
    "build": "npm run build:client && npm run build:ssr && npm run build:server",
    "build:client": "vite build",
    "build:ssr": "vite build --config vite.ssr.config.mjs",
    "build:server": "rimraf dist/events dist/jobs dist/scheduler && tsc --project tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "start": "node dist/index.js",
    "test": "npm run test:integration && npm run test:e2e",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:typecheck": "tsc --pretty false -p tsconfig.tests.json",
    "test:e2e": "playwright test",
    "migration:run": "mikro-orm migration:up",
    "migration:revert": "mikro-orm migration:down",
    "migration:create": "mikro-orm migration:create",
    "migration:status": "mikro-orm migration:check",
    "migrate": "npm run migration:create && npm run migration:run",
    "db:seed": "mikro-orm seeder:run",
    "work": "tsx src/worker.ts",
    "work:prod": "node dist/worker.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@inertiajs/react": "^2.1.11",
    "@mikro-orm/core": "^6.5.8",
    "@mikro-orm/migrations": "^6.5.1",
    "@mikro-orm/postgresql": "^6.5.1",
    "@mikro-orm/seeder": "^6.5.1",
    "@mikro-orm/sqlite": "^6.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express-session": "^1.18.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "dotenv-defaults": "^5.0.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.2",
    "graphile-worker": "^0.16.6",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pg-connection-string": "^2.9.1",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.5.1",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.31",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "vite": "^6.4.0",
    "vitest": "^4.1.7"
  },
  "mikro-orm": {
    "configPaths": [
      "./src/database/orm.config.ts",
      "./dist/database/orm.config.js"
    ]
  }
}
